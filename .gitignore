# Environment configuration file.
.env

# Python bytecode cache directories.
__pycache__/

# Default SQLite database file (often for development).
db.sqlite3

# Directory for collected static files (CSS, JS, etc.).
static/

# Directory for user-uploaded media files (images, videos, etc.).
media/

# Common virtual environment directory names.
venv/
.venv/
env/

# IDE-specific project configuration directories.
.idea/
.vscode/

# Temporary files and logs.
*.swp
*.pyc
*.log

# Executable files.
*.exe