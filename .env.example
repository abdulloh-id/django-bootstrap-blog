# --- Basic Django Settings ---
DEBUG=True
SECRET_KEY=django-insecure-change-me-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (Default for MySQL/Laragon) ---
MYSQL_DATABASE=blog_db
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

# --- Email Settings (Use an App Password for Gmail) ---
DEFAULT_FROM_EMAIL=your-email@gmail.com
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-here

# --- Social Media Links ---
SOCIAL_LINK_FACEBOOK=https://facebook.com/yourprofile
SOCIAL_LINK_TWITTER=https://twitter.com/yourprofile
SOCIAL_LINK_LINKEDIN=https://linkedin.com/in/yourprofile
SOCIAL_LINK_INSTAGRAM=https://instagram.com/yourprofile